DATABASE_URL=postgresql://boxleague:boxleague@postgres:5432/boxleague?schema=public
POSTGRES_DB=boxleague
POSTGRES_USER=boxleague
POSTGRES_PASSWORD=boxleague
POSTGRES_HOST_PORT=15435
WEB_HOST_PORT=13001
NEXT_PUBLIC_APP_NAME=Box League
SEED_ADMIN_PASSWORD=change-me
POSTGRES_DATA_PATH=/mnt/user/appdata/box-league/postgres
# Optional for Unraid Stack "Repository" workflows that build from git
GIT_CONTEXT=https://github.com/sefaction/sealed-commander-league.git#main
DOCKERFILE_PATH=./Dockerfile
# Your Unraid server LAN IP for browser access
UNRAID_HOST_IP=192.168.1.2

# Set to true only if you serve the app over HTTPS
COOKIE_SECURE=false

# Recover from Prisma P3009 failed migration marker on startup
AUTO_RESOLVE_FAILED_MIGRATION=true
# DANGER: set true only if you want to wipe all DB data on startup
WIPE_DB_ON_START=false

# Keep startup stable by default: no demo/seed data unless explicitly enabled
RUN_SEED_ON_START=false
