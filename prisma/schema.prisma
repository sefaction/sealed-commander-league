generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TradeStatus {
  PENDING
  COMPLETED
  CANCELED
}

enum RoundStatus {
  PLANNED
  ACTIVE
  COMPLETED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  playerId     String?
  player       Player?  @relation(fields: [playerId], references: [id])
  createdAt    DateTime @default(now())
}

model League {
  id             String   @id @default(cuid())
  name           String
  slug           String   @unique
  description    String?
  appDisplayName String   @default("Box League")
  seasons        Season[]
  createdAt      DateTime @default(now())
}

model Season {
  id          String       @id @default(cuid())
  leagueId    String
  league      League       @relation(fields: [leagueId], references: [id])
  name        String
  year        Int
  startDate   DateTime
  endDate     DateTime?
  active      Boolean      @default(false)
  rounds      Round[]
  memberships LeaguePlayer[]

  @@unique([leagueId, name])
}

model Player {
  id              String           @id @default(cuid())
  name            String           @unique
  displayName     String           @unique
  email           String?
  active          Boolean          @default(true)
  isAdmin         Boolean          @default(false)
  color           String           @default("#64748b")
  memberships     LeaguePlayer[]
  openedCards     CardOwnership[]  @relation("OpenedBy")
  ownedCards      CardOwnership[]  @relation("OwnedBy")
  users           User[]
  pointEvents     PointEvent[]
  packAllocations PackAllocation[]
  ownedBoxes      SetBox[]         @relation("BoxOwner")
  pulls           Pull[]
  inventoryOwned  InventoryItem[]  @relation("InventoryCurrentOwner")
  inventoryOpened InventoryItem[]  @relation("InventoryOriginalOpener")
}

model LeaguePlayer {
  id       String @id @default(cuid())
  seasonId String
  playerId String
  season   Season @relation(fields: [seasonId], references: [id])
  player   Player @relation(fields: [playerId], references: [id])
  @@unique([seasonId, playerId])
}

model Round {
  id             String   @id @default(cuid())
  seasonId       String
  season         Season   @relation(fields: [seasonId], references: [id])
  name           String
  monthNumber    Int
  startDate      DateTime
  endDate        DateTime?
  status         RoundStatus @default(PLANNED)
  points         PointEvent[]
  setBoxes       SetBox[]
  packAllocations PackAllocation[]
  pulls          Pull[]
  inventoryItems InventoryItem[]
  createdAt      DateTime @default(now())
  @@unique([seasonId, monthNumber])
}

model SetBox {
  id         String @id @default(cuid())
  roundId    String
  round      Round  @relation(fields: [roundId], references: [id])
  setName    String
  setCode    String
  boxType    String
  boxOwnerId String?
  boxOwner   Player? @relation("BoxOwner", fields: [boxOwnerId], references: [id])
  totalPacks Int
  notes      String?
}

model PackAllocation {
  id            String @id @default(cuid())
  roundId        String
  round          Round  @relation(fields: [roundId], references: [id])
  playerId       String
  player         Player @relation(fields: [playerId], references: [id])
  packsAssigned  Int
  packsOpened    Int
  notes          String?

  @@unique([roundId, playerId])
}

model PointCategory {
  id           String @id @default(cuid())
  name         String @unique
  description  String?
  defaultValue Int
  active       Boolean @default(true)
}

model Card {
  id              String   @id @default(cuid())
  scryfallId      String   @unique
  oracleId        String?
  name            String
  manaCost        String?
  manaValue       Float?
  power           String?
  toughness       String?
  loyalty         String?
  defense         String?
  colors          Json?
  colorIdentity   Json?
  typeLine        String
  oracleText      String?
  setCode         String
  keywords        Json?
  legalities      Json?
  setName         String?
  collectorNumber String
  rarity          String
  imageUri        String?
  artist          String?
  imageUris       Json?
  prices          Json?
  purchaseUris    Json?
  scryfallUri     String?
  lastSyncedAt    DateTime?
  ownerships      CardOwnership[]
  pulls           Pull[]
  inventoryItems  InventoryItem[]
}

model Pull {
  id         String   @id @default(cuid())
  roundId     String
  round       Round    @relation(fields: [roundId], references: [id])
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id])
  cardId      String
  card        Card     @relation(fields: [cardId], references: [id])
  quantity    Int
  foil        Boolean  @default(false)
  condition   String
  notes       String?
  createdAt   DateTime @default(now())
  inventoryItems InventoryItem[]
}

model InventoryItem {
  id               String   @id @default(cuid())
  currentOwnerId   String
  currentOwner     Player   @relation("InventoryCurrentOwner", fields: [currentOwnerId], references: [id])
  originalOpenerId String
  originalOpener   Player   @relation("InventoryOriginalOpener", fields: [originalOpenerId], references: [id])
  cardId           String
  card             Card     @relation(fields: [cardId], references: [id])
  quantity         Int
  foil             Boolean  @default(false)
  condition        String
  acquiredFromPullId String?
  acquiredFromPull Pull?    @relation(fields: [acquiredFromPullId], references: [id])
  roundId          String
  round            Round    @relation(fields: [roundId], references: [id])
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([currentOwnerId, originalOpenerId, cardId, foil, condition, roundId])
}

model CardOwnership {
  id               String   @id @default(cuid())
  cardId           String
  originalOpenerId String
  currentOwnerId   String
  quantity         Int      @default(1)
  card             Card     @relation(fields: [cardId], references: [id])
  originalOpener   Player   @relation("OpenedBy", fields: [originalOpenerId], references: [id])
  currentOwner     Player   @relation("OwnedBy", fields: [currentOwnerId], references: [id])
}

model PointEvent {
  id          String   @id @default(cuid())
  roundId     String
  playerId    String
  description String
  points      Int
  round       Round    @relation(fields: [roundId], references: [id])
  player      Player   @relation(fields: [playerId], references: [id])
}
